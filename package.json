    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "react-leaflet": "^5.0.0",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.0",
