{
  "expo": {
    "name": "Seis Pimientas",
    "slug": "seispimientas-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "seispimientas",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C0392B"
    },
    "android": {
      "package": "com.seispimientas.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C0392B"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.USE_BIOMETRIC"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Seis Pimientas necesita tu ubicacion para registrar las entregas.",
          "locationWhenInUsePermission": "Seis Pimientas necesita tu ubicacion para mostrar la ruta."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Usa Face ID para iniciar sesion rapidamente."
        }
      ]
    ],
    "newArchEnabled": false
  }
}
