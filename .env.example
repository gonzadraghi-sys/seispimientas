# ══════════════════════════════════════════
#   SEIS PIMIENTAS · VARIABLES DE ENTORNO
#   Copiá este archivo como .env y completá
#   NUNCA subas .env a git
# ══════════════════════════════════════════

# ── SERVIDOR ──
NODE_ENV=development
PORT=3000

# ── BASE DE DATOS (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seispimientas
DB_USER=sp_user
DB_PASSWORD=tu_password_seguro_aqui
DB_SSL=false

# ── JWT ──
# Generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── BCRYPT ──
BCRYPT_ROUNDS=12

# ── CIFRADO DB EXPORT ──
# Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=cambia_esto_por_clave_aes256_de_64_chars

# ── BACKUPS ──
BACKUP_PATH=./backups
BACKUP_ENCRYPT=true

# ── CORS ──
# Múltiples orígenes separados por coma
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── RATE LIMITING ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── SHOP / E-COMMERCE ──
# JWT para clientes web (distinto al de usuarios internos)
JWT_SECRET_CLIENTES=cambia_esto_por_otra_clave_segura
JWT_CLIENTES_EXPIRES_IN=7d
# URL pública de la tienda (para back_urls de MP, etc.)
SHOP_URL=http://localhost:5174
# ID de la lista de precios para el e-commerce
LISTA_PRECIOS_WEB_ID=uuid_de_la_lista_web
# ID del local desde donde se descuenta stock para pedidos web (ej: depósito)
VENTAS_WEB_LOCAL_ID=uuid_del_deposito
# ID del usuario interno que actúa como "sistema web" (ej: usuario servicio)
USUARIO_WEB_ID=uuid_del_usuario_sistema

# ── MERCADO PAGO ──
# Access Token de MP (producción o test)
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Clave para validar webhooks de MP
MP_WEBHOOK_SECRET=secreto_para_validar_webhooks

# ── IMÁGENES IA (opcional — dejar vacío si no se usan) ──
# Stability AI: https://stability.ai (25 imágenes gratis)
STABILITY_API_KEY=
# OpenAI DALL-E: https://platform.openai.com ($5 crédito gratis)
OPENAI_API_KEY=
# Clipdrop: https://clipdrop.co (100 imágenes gratis/mes)
CLIPDROP_API_KEY=

# ── DATOS BANCARIOS (para transferencia) ──
SHOP_BANCO=Banco Galicia
SHOP_TITULAR=Seis Pimientas S.A.
SHOP_CBU=0070001234567890123456
SHOP_ALIAS=SEISPIMIENTAS.MP
SHOP_CUIL=30-12345678-9
