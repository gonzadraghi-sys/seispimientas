# ══════════════════════════════════════════
#   SEIS PIMIENTAS · VARIABLES DE ENTORNO
#   Copiá este archivo como .env y completá
#   NUNCA subas .env a git
# ══════════════════════════════════════════

# ── SERVIDOR ──
NODE_ENV=development
PORT=3000

# ── BASE DE DATOS (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seispimientas
DB_USER=sp_user
DB_PASSWORD=tu_password_seguro_aqui
DB_SSL=false

# ── JWT (INTERNOS) ──
# Generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_esto_por_otra_clave_distinta
JWT_REFRESH_EXPIRES_IN=7d

# ── JWT (CLIENTES SHOP) ──
# Generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET_CLIENTES=cambia_esto_por_otra_clave_mas
JWT_CLIENTES_EXPIRES_IN=1h

# ── BCRYPT ──
BCRYPT_ROUNDS=12

# ── CIFRADO DB EXPORT ──
# Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=cambia_esto_por_clave_aes256_de_64_chars

# ── BACKUPS ──
BACKUP_PATH=./backups
BACKUP_ENCRYPT=true

# ── CORS ──
# Múltiples orígenes separados por coma
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── RATE LIMITING ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── SHOP / E-COMMERCE ──
SHOP_URL=http://localhost:5174
LISTA_PRECIOS_WEB_ID=uuid_de_la_lista_web
VENTAS_WEB_LOCAL_ID=uuid_del_deposito
USUARIO_WEB_ID=uuid_del_usuario_sistema

# ── MERCADO PAGO ──
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_SECRET=secreto_para_validar_webhooks

# ── IMÁGENES IA (opcional — dejar vacío si no se usan) ──
STABILITY_API_KEY=
OPENAI_API_KEY=
CLIPDROP_API_KEY=

# ── DATOS BANCARIOS (para transferencia) ──
SHOP_BANCO=Banco Galicia
SHOP_TITULAR=Seis Pimientas S.A.
SHOP_CBU=0070001234567890123456
SHOP_ALIAS=SEISPIMIENTAS.MP
SHOP_CUIL=30-12345678-9
